DEBUG=False
SECRET_KEY=replace-with-strong-secret
ALLOWED_HOSTS=fms.example.com,api.fms.example.com

DATABASE_URL=postgres://fms_user:change_me@db-host:5432/fms_db
DB_SSL_REQUIRE=True

CORS_ALLOWED_ORIGINS=https://fms.example.com
CSRF_TRUSTED_ORIGINS=https://fms.example.com,https://api.fms.example.com

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
TIME_ZONE=UTC

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@example.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
