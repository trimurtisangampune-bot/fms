# Root .env — used by docker-compose.yml
# Fill in real values before deployment. Never commit secrets.

DEBUG=False
SECRET_KEY=replace-with-strong-secret
ALLOWED_HOSTS=fms.example.com

DB_NAME=fms_db
DB_USER=fms_user
DB_PASSWORD=change_me_in_production
# Set False for internal docker-compose db container traffic (default).
# Set True only when DATABASE_URL points to an external managed Postgres with SSL.
DB_SSL_REQUIRE=False

CORS_ALLOWED_ORIGINS=https://fms.example.com
CSRF_TRUSTED_ORIGINS=https://fms.example.com

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
TIME_ZONE=UTC

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@example.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# Frontend (used at build-time by docker-compose)
REACT_APP_API_URL=https://fms.example.com/api
# Use immutable tags for production (full commit SHA), not latest.
DB_IMAGE=ghcr.io/trimurtisangampune-bot/fms/db:<full-commit-sha>
BACKEND_IMAGE=ghcr.io/trimurtisangampune-bot/fms/backend:<full-commit-sha>
FRONTEND_IMAGE=ghcr.io/trimurtisangampune-bot/fms/frontend:<full-commit-sha>

# Optional tuning for backend runtime startup
GUNICORN_WORKERS=2
GUNICORN_THREADS=2

BACKEND_PORT=8000
FRONTEND_PORT=80
